# ==============================================================================
# Venus - Environment Variables Example
# ==============================================================================
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
#

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# Your API base URL
# NEXT_PUBLIC_API_URL=https://api.example.com

# API Keys (if needed)
# API_KEY=your-api-key-here
# NEXT_PUBLIC_API_KEY=your-public-api-key

# ==============================================================================
# AUTHENTICATION
# ==============================================================================

# NextAuth.js / Auth.js configuration (if using)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-here

# OAuth Providers (if using)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==============================================================================
# DATABASE
# ==============================================================================

# Database connection string (PostgreSQL, MySQL, MongoDB, etc.)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ==============================================================================
# AI / LLM INTEGRATIONS
# ==============================================================================

# OpenAI API
# OPENAI_API_KEY=sk-...

# Anthropic Claude API
# ANTHROPIC_API_KEY=sk-ant-...

# Other AI providers
# REPLICATE_API_TOKEN=...
# HUGGINGFACE_API_KEY=...

# ==============================================================================
# STORAGE & UPLOADS
# ==============================================================================

# AWS S3 / R2 / Supabase Storage
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ==============================================================================
# ANALYTICS & MONITORING
# ==============================================================================

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=...

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# PostHog
# NEXT_PUBLIC_POSTHOG_KEY=...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry
# SENTRY_DSN=...
# NEXT_PUBLIC_SENTRY_DSN=...

# ==============================================================================
# EMAIL
# ==============================================================================

# Resend
# RESEND_API_KEY=re_...

# SendGrid
# SENDGRID_API_KEY=SG....

# ==============================================================================
# PAYMENTS
# ==============================================================================

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Enable/disable features
# NEXT_PUBLIC_FEATURE_ANALYTICS=true
# NEXT_PUBLIC_FEATURE_AI_CHAT=true

# ==============================================================================
# DEVELOPMENT
# ==============================================================================

# Development mode settings
# NODE_ENV=development
# NEXT_PUBLIC_ENV=development
