{
  "name": "venus-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "build": "pnpm --filter venuscn build && pnpm --filter demo build",
    "build:packages": "pnpm --filter './packages/*' build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules .next dist"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
